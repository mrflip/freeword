{
  "$schema":  "https://json.schemastore.org/tsconfig",
  "display":  "Node 23",
  "exclude":  ["node_modules", "built", "**/built/**/*", "built/**/*", "**/.yarn/**/*", "**/aside/**/*"],
  "extends":  "../tsconfig-base.json",
  //
  "compilerOptions": {
    // where do we sit in the world?
    "rootDir":                            "..",
    "composite":                          false, // not referenced by others
    // when (never) and where (out of sight) to put the build artifacts
    "tsBuildInfoFile":                    "../../../.tsbuildinfo-freeword-all-byword-tests",
    "outDir":                             "../built/freeword-all-byword-tests",
    "noEmit":                             true,
    //
    "isolatedModules":                    true,   /* ts-jest wants this */
    "preserveSymlinks":                   true,
    //
    // "paths": {  /* make the tests work with the monorepo, so local package imports work */
    // // "@freeword/all-byword":        ["../index.ts"],
    // // "@freeword/all-byword/*":      ["../*"]
    //   "@freeword/meta":                 ["./meta/src/index.ts"],
    //   "@freeword/meta/*":               ["./meta/src/*"]
    // },
    /* specify one, you have to specify all; testGlobals makes ts-jest work with jest+chai mix */
    "types":                              ["./testGlobals.d.ts", "jest", "chai", "node", "sinon"],
    // true to see super-long error messages
    "noErrorTruncation":                  false
  }
}
