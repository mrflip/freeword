{
  "$schema":                "https://json.schemastore.org/tsconfig",
  "extends":                "./tsconfig-base.json",
  // "include":                            ["src/**/*.ts", "db/**/*.ts", "src/**/*.js"],
  "compilerOptions": {
    "tsBuildInfoFile":                    "./.tsbuildinfo-freeword-internals",
    "outDir":                             "./built/internals",  /* Specify the path to .tsbuildinfo incremental compilation file. */
    "lib":                                ["esnext"],
    "incremental":                        true,
    "noEmit":                             true, /* Disable emitting files from a compilation. */
    "noErrorTruncation":                  false // true to see all errors
  }
}
