{
  "name": "@freeword/meta",
  "version": "1.0.22",
  "description": "Meta package for Freeword: exports all core types, constants, and utilities from the src/ directory.",
  "scripts": {
    "shipme": "         npm publish --access public",
    "build": "          yarn tsc   --build --verbose && yarn build:cjs",
    "build:cjs": "      yarn tsup",
    "ts:watch": "       yarn tsc   --build --verbose --watch",
    "_1": " echo .",
    "test": "           cd .. ; yarn test ",
    "test:plain": "     cd .. ; yarn test ",
    "test:coverage": "  cd .. ; yarn test --coverage ",
    "test:watch": "     cd .. ; yarn test --watch    ",
    "twitch": "         cd .. ; yarn node --experimental-vm-modules --enable-source-maps $(yarn bin jest) --watch",
    "_2": " echo .",
    "_z": "echo ."
  },
  "dependencies": {
    "esm-seedrandom": "3.0.5-esm.2",
    "fast-json-stable-stringify": "^2.1.0",
    "lodash": "^4.17.21",
    "luxon": "^3.6.1",
    "snowball-stemmers": "^0.6.0",
    "sprintf-js": "^1.1.3",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@jest/globals": "^30.0.4",
    "@jest/types": "^30.0.1",
    "@types/chai": "^5.2.2",
    "@types/chai-arrays": "^2.0.3",
    "@types/chai-as-promised": "^8.0.2",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.18",
    "@types/luxon": "^3",
    "@types/node": "^24.0.14",
    "@types/sinon": "^17.0.4",
    "@types/sinon-chai": "^4.0.0",
    "@types/snowball-stemmers": "^0.6.2",
    "@types/sprintf-js": "^1",
    "chai": "^5.2.0",
    "jest": "^30.0.2",
    "jest-util": "^30.0.2",
    "sinon": "^21.0.0",
    "sinon-chai": "^4.0.0",
    "ts-jest": "^29.4.0",
    "ts-jest-resolver": "^2.0.1",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3"
  },
  "keywords": [
    "dictionary",
    "wordforms",
    "language",
    "typescript",
    "morphology",
    "linguistics"
  ],
  "author": "flip kromer and the freeword team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mrflip/freeword.git"
  },
  "type": "module",
  "main": "./built/index.js",
  "types": "./built/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "types": "./built/index.d.ts",
        "default": "./built/index.js"
      },
      "require": {
        "types": "./built-cjs/index.d.cts",
        "default": "./built-cjs/index.cjs"
      }
    },
    "./checks": {
      "import": {
        "types": "./built/src/checks.d.ts",
        "default": "./built/src/checks.js"
      }
    },
    "./checks.js": {
      "import": {
        "types": "./built/src/checks.d.ts",
        "default": "./built/src/checks.js"
      }
    },
    "./UF.js": {
      "import": {
        "types": "./built/src/utils/UF.d.ts",
        "default": "./built/src/utils/UF.js"
      }
    },
    "./Wordbits.js": {
      "import": {
        "types": "./built/src/lib/Wordbits.d.ts",
        "default": "./built/src/lib/Wordbits.js"
      }
    },
    "./Wordform.js": {
      "import": {
        "types": "./built/src/lexicon/index.d.ts",
        "default": "./built/src/lexicon/index.js"
      }
    },
    "./Filer.js": {
      "import": {
        "types": "./built/src/lib/Filer.d.ts",
        "default": "./built/src/lib/Filer.js"
      }
    },
    "./UF": {
      "import": {
        "types": "./built/src/utils/UF.d.ts",
        "default": "./built/src/utils/UF.js"
      }
    },
    "./Wordbits": {
      "import": {
        "types": "./built/src/lib/Wordbits.d.ts",
        "default": "./built/src/lib/Wordbits.js"
      }
    },
    "./Wordform": {
      "import": {
        "types": "./built/src/lexicon/index.d.ts",
        "default": "./built/src/lexicon/index.js"
      }
    },
    "./Filer": {
      "import": {
        "types": "./built/src/lib/Filer.d.ts",
        "default": "./built/src/lib/Filer.js"
      }
    }
  },
  "files": [
    "built",
    "built-cjs",
    "src",
    "tsconfig*.json",
    "tsup.config.ts",
    "VERSION.txt",
    "README.md",
    "package.json",
    "index.ts"
  ],
  "packageManager": "yarn@4.9.2"
}
