{
  "$schema":  "https://json.schemastore.org/tsconfig",
  "display":  "Node 23",
  "exclude":  ["node_modules", "built", "**/built/**/*", "tests", "**/tests/**/*"],
  "extends":  "./tsconfig-base.json",
  //
  "compilerOptions": {
    // where do we sit in the world?
    "rootDir":                            ".",
    "composite":                          true,   // and not referenced by others
    "tsBuildInfoFile":                    "../../.tsbuildinfo-freeword-all-byword",
    "outDir":                             "./built/freeword-all-byword",
    "noEmit":                             false,
    //
    "checkJs":                            false, // not for the big files
    //
    // "paths": {  /* make the tests work with the monorepo, so local package imports work */
    //   "@freeword/meta":                   ["./tests/meta/src/index.ts"],
    //   "@freeword/meta/*":                 ["./tests/meta/src/*"]
    // },
    "preserveSymlinks":                   true,
    // temp switch to true to see super-long error messages
    "noErrorTruncation":                  false
  }
}
