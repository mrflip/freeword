{
  "$schema":  "https://json.schemastore.org/tsconfig",
  "display":  "Node 23",
  "exclude":  ["node_modules", "built", "**/built/**/*", "built/**/*", "**/.yarn/**/*", "**/aside/**/*"],
  "extends":  "../tsconfig.json",
  //
  "compilerOptions": {
    "tsBuildInfoFile":                    "../.tsbuildinfo-freeword-tests",
    "outDir":                             "../built-freeword-tests",
    "rootDir":                            "..",
    //
    "noEmit":                             true,
    "composite":                          false,
    "isolatedModules":                    true,

    // Strictness settings
    // "noImplicitAny":                      false,
    // "noImplicitOverride":                 false,
    // "noUnusedLocals":                     false,
    //
    "paths": {
      "@freeword/meta": ["../meta/src/index.ts"],
      "@freeword/meta/*": ["../meta/src/*"],
      "@freeword/all-byword": ["../repos/freeword-all-byword/index.ts"],
      "@freeword/all-byword/*": ["../repos/freeword-all-byword/*"]
      // Remove or comment out the old '@/...' mappings
      // "@": ["../src"],
      // "@/*": ["../src/*"]
    },
    "types":                              ["./testGlobals.d.ts", "jest", "chai", "node", "sinon", "snowball-stemmers"],
    "noErrorTruncation":                  false  // true to see super-long error messages
  }
}
